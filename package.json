{
  "name": "grapestrap",
  "version": "0.0.1-alpha.0",
  "description": "Visual Bootstrap 5 editor for Linux. Dreamweaver alternative, MIT, no telemetry.",
  "main": "dist/main/main.js",
  "type": "module",
  "homepage": "https://grapestrap.org",
  "repository": {
    "type": "git",
    "url": "https://github.com/grapestrap/grapestrap"
  },
  "license": "MIT",
  "author": "GrapeStrap Contributors",
  "scripts": {
    "dev": "vite",
    "start": "electron .",
    "build": "vite build",
    "build:deb": "npm run build && electron-builder --linux deb",
    "build:appimage": "npm run build && electron-builder --linux AppImage",
    "build:rpm": "npm run build && electron-builder --linux rpm",
    "build:tarball": "npm run build && electron-builder --linux tar.gz",
    "build:linux": "npm run build && electron-builder --linux deb AppImage tar.gz",
    "test:e2e": "playwright test",
    "lint": "eslint src/ plugins/"
  },
  "dependencies": {
    "@splidejs/splide": "^4.1.4",
    "bootstrap": "^5.3.3",
    "bootstrap-icons": "^1.11.3",
    "chokidar": "^3.6.0",
    "electron-log": "^5.1.5",
    "electron-store": "^10.0.0",
    "glightbox": "^3.3.0",
    "golden-layout": "^2.6.0",
    "grapesjs": "^0.21.10",
    "grapesjs-blocks-bootstrap5": "^0.2.31",
    "i18next": "^23.11.5",
    "monaco-editor": "^0.50.0",
    "notyf": "^3.10.0",
    "prettier": "^3.3.2",
    "semver": "^7.6.2",
    "simple-git": "^3.25.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.45.1",
    "concurrently": "^8.2.2",
    "electron": "^31.1.0",
    "electron-builder": "^24.13.3",
    "eslint": "^9.6.0",
    "vite": "^5.3.3",
    "vite-plugin-electron": "^0.28.7",
    "vite-plugin-electron-renderer": "^0.14.5"
  },
  "build": {
    "appId": "org.grapestrap.GrapeStrap",
    "productName": "GrapeStrap",
    "copyright": "Copyright © 2026 GrapeStrap Contributors",
    "asar": true,
    "directories": {
      "output": "release"
    },
    "linux": {
      "target": [
        "deb",
        "AppImage",
        "tar.gz"
      ],
      "category": "Development",
      "icon": "assets/icons/icon.png",
      "synopsis": "Dreamweaver-style visual editor for Bootstrap 5",
      "description": "GrapeStrap is a desktop visual editor for building static Bootstrap 5 websites. Class-first styling, Dreamweaver-faithful workflow, plugin-extensible, no telemetry.",
      "mimeTypes": [
        "application/x-grapestrap"
      ],
      "desktop": {
        "Name": "GrapeStrap",
        "Comment": "Visual Bootstrap 5 editor for Linux",
        "Categories": "Development;WebDevelopment;",
        "Keywords": "html;css;bootstrap;web;editor;dreamweaver;visual;",
        "MimeType": "application/x-grapestrap;",
        "StartupWMClass": "GrapeStrap"
      }
    },
    "deb": {
      "depends": [
        "libgtk-3-0",
        "libnotify4",
        "libnss3",
        "libxss1",
        "libxtst6",
        "xdg-utils",
        "libatspi2.0-0",
        "libsecret-1-0"
      ]
    },
    "appImage": {
      "license": "LICENSE"
    },
    "files": [
      "dist/**/*",
      "plugins/**/*",
      "assets/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "packaging/desktop/grapestrap-mime.xml",
        "to": "mime/grapestrap-mime.xml"
      }
    ]
  }
}
